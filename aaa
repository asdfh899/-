    def _crazy():
        end = time.time() + seconds
        while time.time() < end:
            if pattern == "원":
                angle = random.uniform(0, 2 * 3.14159)
                r = random.randint(50, 300)
                x = sw/2 + r * math.cos(angle)
                y = sh/2 + r * math.sin(angle)
            elif pattern == "사각형":
                x = random.randint(100, sw-100)
                y = random.randint(100, sh-100)
            else:  # 랜덤
                x = random.randint(0, sw)
                y = random.randint(0, sh)
            pyautogui.moveTo(x, y, duration=speed)
    threading.Thread(target=_crazy, daemon=True).start()

