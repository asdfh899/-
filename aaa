@bot.command(name="earthquake")
async def earthquake(ctx, seconds: int, intensity: int = 15):
    if seconds < 1 or seconds > 30: return await ctx.send("1~30초")
    if intensity < 1 or intensity > 50: intensity = 15
    await ctx.send(f"🌍 **지진 시작:** {seconds}초, 강도 {intensity}px")
    def _shake():
        end = time.time() + seconds
        while time.time() < end:
            def _enum(hwnd, _):
                if win32gui.IsWindowVisible(hwnd):
                    try:
                        r = win32gui.GetWindowRect(hwnd)
                        dx = random.randint(-intensity, intensity)
                        dy = random.randint(-intensity, intensity)
                        win32gui.MoveWindow(hwnd, r[0]+dx, r[1]+dy, r[2]-r[0], r[3]-r[1], True)
                    except: pass
            try: win32gui.EnumWindows(_enum, None)
            except: pass
            time.sleep(0.04)
    threading.Thread(target=_shake, daemon=True).start()

