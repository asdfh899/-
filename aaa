def mouse_art(shape, duration=10.0, speed=0.01):
    """shape: 원, 사각형, 삼각형, duration: 초, speed: step 간격 (초)"""
    start_time = time.time()
    sw, sh = pyautogui.size()
    center_x, center_y = sw//2, sh//2
    radius = 200
    size = 300

    if shape == "원":
        while time.time() - start_time < duration:
            for angle in range(0, 360, 5):
                x = center_x + radius * math.cos(math.radians(angle))
                y = center_y + radius * math.sin(math.radians(angle))
                pyautogui.moveTo(x, y, duration=speed)
                if time.time() - start_time >= duration:
                    break
    elif shape == "사각형":
        half = size//2
        points = [
            (center_x - half, center_y - half),
            (center_x + half, center_y - half),
            (center_x + half, center_y + half),
            (center_x - half, center_y + half)
        ]
        while time.time() - start_time < duration:
            for i in range(4):
                x1, y1 = points[i]
                x2, y2 = points[(i+1)%4]
                steps = 30
                for j in range(steps):
                    t = j / steps
                    x = x1 + (x2 - x1) * t
                    y = y1 + (y2 - y1) * t
                    pyautogui.moveTo(x, y, duration=speed)
                    if time.time() - start_time >= duration:
                        break
                if time.time() - start_time >= duration:
                    break
    elif shape == "삼각형":
        half = size//2
        points = [
            (center_x, center_y - half),
            (center_x + half * math.sin(math.radians(60)), center_y + half * math.cos(math.radians(60))),
            (center_x - half * math.sin(math.radians(60)), center_y + half * math.cos(math.radians(60)))
        ]
        while time.time() - start_time < duration:
            for i in range(3):
                x1, y1 = points[i]
                x2, y2 = points[(i+1)%3]
                steps = 30
                for j in range(steps):
                    t = j / steps
                    x = x1 + (x2 - x1) * t
                    y = y1 + (y2 - y1) * t
                    pyautogui.moveTo(x, y, duration=speed)
                    if time.time() - start_time >= duration:
                        break
                if time.time() - start_time >= duration:
                    break

